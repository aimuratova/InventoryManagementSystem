@using InventoryManagementSystem.Models;
@using System.Data;
@using Markdig;
@model InventoryItemDetailVM;
@{
	ViewBag.Title = "Inventory details";
}
@section Styles {
    <style>
        html, body {
            height: 100%;
            margin: 0;
        }

        .full-height {
            height: 100vh;
        }

        .container {
            margin-left: inherit;
            padding: 0;
        }

        .left-panel {
            background-color: #f8f9fa;
            border-right: 1px solid #dee2e6;
        }

        .comment-section {
            border-top: 1px solid #dee2e6;
            background: #ffffff;
        }

        .scrollable {
            overflow-y: auto;
        }
    </style>
}

<div class="container-fluid full-height d-flex flex-column">
    <div class="row flex-grow-1">

        <div class="col-md-3 left-panel p-4 scrollable">
            <h4 class="mb-4">Inventory Details</h4>
            
            <div class="mt-3 text-end authenticate" id="divSettings">
                @* <a href="@string.Format("/{0}/{1}?inventoryId={2}", "Inventory", "Edit", Model.Id)"
                   class="btn btn-outline-secondary btn-sm">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-pencil-square" viewBox="0 0 16 16">
                        <path d="M15.502 1.94a.5.5 0 0 1 0 .706L14.459 3.69l-2-2L13.502.646a.5.5 0 0 1 .707 0l1.293 1.293zm-1.75 2.456-2-2L4.939 9.21a.5.5 0 0 0-.121.196l-.805 2.414a.25.25 0 0 0 .316.316l2.414-.805a.5.5 0 0 0 .196-.12l6.813-6.814z" />
                        <path fill-rule="evenodd" d="M1 13.5A1.5 1.5 0 0 0 2.5 15h11a1.5 1.5 0 0 0 1.5-1.5v-6a.5.5 0 0 0-1 0v6a.5.5 0 0 1-.5.5h-11a.5.5 0 0 1-.5-.5v-11a.5.5 0 0 1 .5-.5H9a.5.5 0 0 0 0-1H2.5A1.5 1.5 0 0 0 1 2.5z" />
                    </svg>
                </a>
                <a href="#" id="deleteBtn" data-id="@Model.Id"
                   class="btn btn-outline-secondary btn-sm">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-trash3" viewBox="0 0 16 16">
                        <path d="M6.5 1h3a.5.5 0 0 1 .5.5v1H6v-1a.5.5 0 0 1 .5-.5M11 2.5v-1A1.5 1.5 0 0 0 9.5 0h-3A1.5 1.5 0 0 0 5 1.5v1H1.5a.5.5 0 0 0 0 1h.538l.853 10.66A2 2 0 0 0 4.885 16h6.23a2 2 0 0 0 1.994-1.84l.853-10.66h.538a.5.5 0 0 0 0-1zm1.958 1-.846 10.58a1 1 0 0 1-.997.92h-6.23a1 1 0 0 1-.997-.92L3.042 3.5zm-7.487 1a.5.5 0 0 1 .528.47l.5 8.5a.5.5 0 0 1-.998.06L5 5.03a.5.5 0 0 1 .47-.53Zm5.058 0a.5.5 0 0 1 .47.53l-.5 8.5a.5.5 0 1 1-.998-.06l.5-8.5a.5.5 0 0 1 .528-.47M8 4.5a.5.5 0 0 1 .5.5v8.5a.5.5 0 0 1-1 0V5a.5.5 0 0 1 .5-.5" />
                    </svg>
                </a> *@
            </div>

            <div class="mb-3">
                <label class="form-label text-muted">Title</label>
                <div class="fw-bold" id="inventoryTitle">@Model.Title</div>
            </div>

            <div class="mb-3">
                <label class="form-label text-muted">Category</label>
                <div class="fw-bold" id="categoryTitle">@Model.CategoryTitle</div>
            </div>

            <div class="mb-3">
                <label class="form-label text-muted">Access Status</label>
                @if (Model.IsPublic)
                {
                    <span class="badge bg-success">Public</span>
                }
                else
                {
                    <span class="badge bg-secondary">Private</span>
                }
            </div>

            <div class="mb-3">
                <label class="form-label text-muted">Author</label>
                <div id="authorTitle">@Model.CreatedBy</div>
            </div>

            <div class="mb-3">
                <label class="form-label text-muted">Created Date</label>
                <div id="createDateTitle">@Model.CreatedAt.ToShortDateString()</div>
            </div>

            <div class="mb-3">
                <label class="form-label text-muted">Description</label>
                <div id="descriptionTitle">@Html.Raw(Markdown.ToHtml(Model.Description))</div>
            </div>
        </div>

        <div class="col-md-9 p-4 scrollable">

            <h4 class="mb-4">Inventory</h4>

            <ul class="nav nav-tabs" id="myTab" role="tablist">
                <li class="nav-item" role="presentation">
                    <button class="nav-link active" id="home-tab" data-bs-toggle="tab" data-bs-target="#home-tab-pane" type="button" role="tab" aria-controls="home-tab-pane" aria-selected="true">Fields</button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link" id="profile-tab" data-bs-toggle="tab" data-bs-target="#profile-tab-pane" type="button" role="tab" aria-controls="profile-tab-pane" aria-selected="false">Values</button>
                </li>
               @*  <li class="nav-item" role="presentation">
                    <button class="nav-link" id="contact-tab" data-bs-toggle="tab" data-bs-target="#contact-tab-pane" type="button" role="tab" aria-controls="contact-tab-pane" aria-selected="false">Custom ID</button>
                </li>    *@             
            </ul>
            <div class="tab-content" id="myTabContent" style="min-height: 50%;">
                <div class="tab-pane fade show active" id="home-tab-pane" role="tabpanel" aria-labelledby="home-tab" tabindex="0">
                    <div class="card shadow-sm">
                        <div class="card-header bg-white">
                            <h5 class="mb-0">Fields Table</h5>
                        </div>

                        <div class="card-body">
                            <div class="table-responsive">
                                <table class="table table-bordered align-middle">
                                    <thead class="table text-center">
                                        <tr>
                                            <th>#</th>
                                            <th>Field Type</th>
                                            <th>Title</th>
                                            <th>Description</th>
                                            <th>IsDisplayed</th>
                                        </tr>
                                    </thead>

                                    <tbody>
                                        @if (Model.Fields != null && Model.Fields.Count > 0)
                                        {
                                            @foreach (var field in Model.Fields)
                                            {
                                                <tr>
                                                    <td>@field.OrderNum</td>
                                                    <td>@field.TypeTitle</td>
                                                    <td>@field.Title</td>
                                                    <td>@field.Description</td>
                                                    <td class="text-center">
                                                        @if (field.IsDisplayed)
                                                        {
                                                            <span class="badge bg-success">Yes</span>
                                                        }
                                                        else
                                                        {
                                                            <span class="badge bg-secondary">No</span>
                                                        }
                                                    </td>                                                    
												</tr>

                                            }
                                        }                                       
                                    </tbody>
                                </table>
                            </div>

                        </div>
                    </div>
                </div>
                <div class="tab-pane fade" id="profile-tab-pane" role="tabpanel" aria-labelledby="profile-tab" tabindex="0">
                    <partial name="_Value" model="Model" />
                </div>
              
            </div>            
        </div>
    </div>

</div>

@section Scripts {
    <script>
        $(document).ready(function () {

			var token = localStorage.getItem('authToken');

            if(!token) {
                $('.authenticate').hide();
            }

            $.ajax({
                url: '@Url.Action("GetAccessForInventory", "Users")'+'?inventoryId='+@Model.Id,
                headers: {'Authorization': 'Bearer ' + token},
                method: 'GET',
                success: function (response) {
                    
                    if(response) {

                        $('#divSettings').append(`
                            <a href="/Inventory/Edit?inventoryId=${@Model.Id}"
                               class="btn btn-outline-secondary btn-sm">
                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-pencil-square" viewBox="0 0 16 16">
                                    <path d="M15.502 1.94a.5.5 0 0 1 0 .706L14.459 3.69l-2-2L13.502.646a.5.5 0 0 1 .707 0l1.293 1.293zm-1.75 2.456-2-2L4.939 9.21a.5.5 0 0 0-.121.196l-.805 2.414a.25.25 0 0 0 .316.316l2.414-.805a.5.5 0 0 0 .196-.12l6.813-6.814z" />
                                    <path fill-rule="evenodd" d="M1 13.5A1.5 1.5 0 0 0 2.5 15h11a1.5 1.5 0 0 0 1.5-1.5v-6a.5.5 0 0 0-1 0v6a.5.5 0 0 1-.5.5h-11a.5.5 0 0 1-.5-.5v-11a.5.5 0 0 1 .5-.5H9a.5.5 0 0 0 0-1H2.5A1.5 1.5 0 0 0 1 2.5z" />
                                </svg>
                            </a>
                            <a href="#" id="deleteBtn" data-id="${@Model.Id}"
                               class="btn btn-outline-secondary btn-sm">
                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-trash3" viewBox="0 0 16 16">
                                    <path d="M6.5 1h3a.5.5 0 0 1 .5.5v1H6v-1a.5.5 0 0 1 .5-.5M11 2.5v-1A1.5 1.5 0 0 0 9.5 0h-3A1.5 1.5 0 0 0 5 1.5v1H1.5a.5.5 0 0 0 0 1h.538l.853 10.66A2 2 0 0 0 4.885 16h6.23a2 2 0 0 0 1.994-1.84l.853-10.66h.538a.5.5 0 0 0 0-1zm1.958 1-.846 10.58a1 1 0 0 1-.997.92h-6.23a1 1 0 0 1-.997-.92L3.042 3.5zm-7.487 1a.5.5 0 0 1 .528.47l.5 8.5a.5.5 0 0 1-.998.06L5 5.03a.5.5 0 0 1 .47-.53Zm5.058 0a.5.5 0 0 1 .47.53l-.5 8.5a.5.5 0 1 1-.998-.06l.5-8.5a.5.5 0 0 1 .528-.47M8 4.5a.5.5 0 0 1 .5.5v8.5a.5.5 0 0 1-1 0V5a.5.5 0 0 1 .5-.5" />
                                </svg>
                            </a>
                        `);
                    }
                },
                error: function (error) {
                    console.log('Failed to get inventory access info' + error);                    
                }
            });
                      
		});

        $(document).on("click", "#deleteBtn", function (e) {
            
            e.preventDefault();
            var token = localStorage.getItem('authToken');

            var id = $(this).data("id");

            var confirmation = confirm("Are you sure you want to delete this item?");

            if (confirmation === true) {

                $.ajax({
                    url: '@Url.Action("Delete", "Inventory")'+'?inventoryId='+id,
                    headers: {'Authorization': 'Bearer ' + token},
                    method: 'DELETE',
                    success: function (response) {
                        if(response.success) {
                            window.location.href = '@Url.Action("Index", "Home")';
                        }
                    },
                    error: function (error) {
                        console.log('Failed to delete inventory.' + error);
                        $('body').prepend('<div class="alert alert-danger" role="alert">Failed to delete inventory. Please try again. '+error.message+'</div>');
                    }
                });
            }
        });
    </script>
	<script src="~/js/valuescript.js"></script>
}