<!DOCTYPE html>
<html lang="en">
<head>
	<meta charset="utf-8" />
	<meta name="viewport" content="width=device-width, initial-scale=1.0" />
	<title>@ViewData["Title"] - InventoryManagementSystem</title>
	<link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
	<link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
	<link rel="stylesheet" href="~/InventoryManagementSystem.styles.css" asp-append-version="true" />
	<link rel="stylesheet" href="~/css/theme.css" />
	<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
	@await RenderSectionAsync("Styles", required: false)
</head>
<body>
	<header>
		<nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
			<div class="container-fluid">
				<a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">InventoryManagementSystem</a>
				<button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
						aria-expanded="false" aria-label="Toggle navigation">
					<span class="navbar-toggler-icon"></span>
				</button>
				<div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
					<ul class="navbar-nav flex-grow-1">
						<li class="nav-item">
							<a class="nav-link" asp-area="" asp-controller="Home" asp-action="Index">Home</a>
						</li>
					</ul>
					<ul class="navbar-nav ms-auto align-items-center gap-3">
						<li class="nav-item">
							<div class="form-check form-switch m-0">
								<input class="form-check-input" type="checkbox" id="themeToggle">
								<label class="form-check-label small" for="themeToggle">Dark</label>
							</div>
						</li>
					</ul>
					<ul class="navbar-nav">
						<li class="nav-item dropdown" id="authMenu" style="display:none">
							<a class="nav-link dropdown-toggle d-flex align-items-center" href="#" id="userMenu" role="button"
							   data-bs-toggle="dropdown" aria-expanded="false">
							</a>
							<ul class="dropdown-menu dropdown-menu-end shadow" aria-labelledby="userMenu">
								<li id="adminMenu" style="display:none">
									<a class="dropdown-item" asp-controller="Users" asp-action="List">Administration</a>
								</li>
								<li>
									<a class="dropdown-item" asp-controller="ExternalServices" asp-action="SyncToSf">Sync to Salesforce</a>
								</li>
								<li>
									<a class="dropdown-item text-danger" asp-controller="Account" asp-action="LogOut">Logout</a>
								</li>
							</ul>
						</li>

						<li class="nav-item nonAuthMenuClass">
							<a class="nav-link" asp-controller="Account" asp-action="Login">Login</a>
						</li>
						<li class="nav-item nonAuthMenuClass">
							<a class="nav-link" asp-controller="Account" asp-action="Register">Register</a>
						</li>
					</ul>
				</div>
			</div>
		</nav>
	</header>
	<div class="container">
		<main role="main" class="pb-3">
			@RenderBody()
		</main>
	</div>

	<button type="button" class="btn btn-danger rounded-circle p-2 position-fixed d-flex align-items-center justify-content-center"
			style="bottom:20px; right:20px; z-index:9999; width:50px; height:50px;"
			data-bs-toggle="modal"
			data-bs-target="#supportModal">
		<i class="bi bi-info-circle" style="font-size: 2rem;"></i>
	</button>
	<div class="modal fade" id="supportModal" tabindex="-1">
		<div class="modal-dialog">
			<div class="modal-content">
				<div class="modal-header">
					<h5>Create Support Ticket</h5>
					<button type="button" class="btn-close" data-bs-dismiss="modal"></button>
				</div>

				<div class="modal-body">
					<form id="supportForm">
						<div class="mb-3">
							<label>Summary</label>
							<textarea class="form-control" id="summary" required></textarea>
						</div>

						<div class="mb-3">
							<label>Priority</label>
							<select class="form-control" id="priority">
								<option>High</option>
								<option>Average</option>
								<option>Low</option>
							</select>
						</div>
					</form>

					<div id="ticketSuccess" class="alert alert-success d-none">
						Ticket submitted successfully!
					</div>
				</div>

				<div class="modal-footer">
					<button class="btn btn-primary" id="submitTicket">
						Submit
					</button>
				</div>
			</div>
		</div>
	</div>


	<script src="~/lib/jquery/dist/jquery.min.js"></script>
	<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
	<script src="~/js/site.js" asp-append-version="true"></script>
	@await RenderSectionAsync("Scripts", required: false)
	<script>
		$(document).ready(function () {
			const token = localStorage.getItem('authToken');
			if (token) {
				$.ajax({
					url: '/Users/GetUser',
					type: 'GET',
					headers: {
						'Authorization': 'Bearer ' + token
					},
					success: function (data) {
						// Пользователь авторизован, можно отобразить его данные
						$(".nonAuthMenuClass").hide();
						$("#authMenu").show();
						$('#userMenu').html(data.user.email);
						if (data.user.isAdmin) {
							$('#adminMenu').show();
						}
					},
					error: function (jqXHR, textStatus, errorThrown) {
						console.error('Error:', textStatus, errorThrown);
						$('#errorLabel').text(jqXHR.responseText).show();
						$("#authMenu").hide();
						$(".nonAuthMenuClass").show();
					}
				});
			}

			let theme = localStorage.getItem("theme");

			if (theme) {
				$("body").addClass(theme);
			} else {
				$("body").addClass("light-mode");
			}

			$("#themeToggle").click(function () {

				if ($("body").hasClass("light-mode")) {
					$("body").removeClass("light-mode").addClass("dark-mode");

					$("[class*='light']").each(function () {
						let classes = $(this).attr("class").split(" ");

						let newClasses = classes.map(c => c.replace(/light/g, "dark"));

						$(this).attr("class", newClasses.join(" "));
					});

					localStorage.setItem("theme", "dark-mode");
				}
				else {
					$("body").removeClass("dark-mode").addClass("light-mode");

					$("[class*='dark']").each(function () {
						let classes = $(this).attr("class").split(" ");

						let newClasses = classes.map(c => c.replace(/dark/g, "light"));

						$(this).attr("class", newClasses.join(" "));
					});

					localStorage.setItem("theme", "light-mode");
				}

			});


			$("#submitTicket").click(function () {
				
				const url = new URL(window.location.href);
				const inventoryId = url.searchParams.get("inventoryId");

				const ticket = {
					inventoryId: inventoryId,
					link: window.location.href,
					summary: $("#summary").val(),
					priority: $("#priority").val(),
				};

				$.ajax({
					url: "/Support/Create",
					method: "POST",
					headers: {
						'Authorization': 'Bearer ' + token
					},
					contentType: "application/json",
					data: JSON.stringify(ticket),
					success: function () {
						$("#ticketSuccess").removeClass("d-none");
						$("#supportForm")[0].reset();
					},
					error: function () {
						alert("Error submitting ticket");
					}
				});
			});
		});
	</script>
</body>
</html>
