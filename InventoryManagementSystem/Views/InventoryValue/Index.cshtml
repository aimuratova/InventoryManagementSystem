@model InventoryValueViewModel;
@{
	ViewBag.Title = "Inventory value details";
}
@section Styles {
    <style>
        html, body {
            height: 100%;
            margin: 0;
        }

        .full-height {
            height: 100vh;
        }

        .container {
            margin-left: inherit;
            padding: 0;
        }

        .left-panel {
            background-color: #f8f9fa;
            border-right: 1px solid #dee2e6;
        }

        .comment-section {
            border-top: 1px solid #dee2e6;
            background: #ffffff;
        }

        .scrollable {
            overflow-y: auto;
        }

        .row + .row {
            margin-top: 8px;
        }
    </style>
}

<div class="container-fluid full-height d-flex flex-column">
    <div class="row flex-grow-1">

        <partial name="Inventory/_Info" model="Model.BasicInfo" />

        <div class="col-md-9 p-4 scrollable">
            <h4 class="mb-4">Inventory Value</h4>
                
            <div class="container-fluid border rounded p-3 bg-light">
                
                <div class="d-flex justify-content-end mb-3" id="valueSettings">
                </div>

                @foreach (var field in Model.Fields)
                {
                    <div class="row py-2">

                        <div class="col-md-4 fw-semibold text-secondary">
                            @field.Title
                        </div>

                        <div class="col-md-8">
                            @{
                                var value = field.TypeId switch
                                {
                                    (int)DataTypeEnum.Singleline1 => Model.MainInfo.Singleline1,
                                    (int)DataTypeEnum.Singleline2 => Model.MainInfo.Singleline2,
                                    (int)DataTypeEnum.Singleline3 => Model.MainInfo.Singleline3,

                                    (int)DataTypeEnum.Multiline1 => Model.MainInfo.Multiline1,
                                    (int)DataTypeEnum.Multiline2 => Model.MainInfo.Multiline2,
                                    (int)DataTypeEnum.Multiline3 => Model.MainInfo.Multiline3,

                                    (int)DataTypeEnum.Num1 => Model.MainInfo.Num1?.ToString(),
                                    (int)DataTypeEnum.Num2 => Model.MainInfo.Num2?.ToString(),
                                    (int)DataTypeEnum.Num3 => Model.MainInfo.Num3?.ToString(),

                                    (int)DataTypeEnum.Check1 => (Model.MainInfo.Check1 ?? false) ? "True" : "False",
                                    (int)DataTypeEnum.Check2 => (Model.MainInfo.Check2 ?? false) ? "True" : "False",
                                    (int)DataTypeEnum.Check3 => (Model.MainInfo.Check3 ?? false) ? "True" : "False",

                                    (int)DataTypeEnum.Datetime1 => Model.MainInfo.Datetime1?.ToString("yyyy-MM-dd HH:mm"),
                                    (int)DataTypeEnum.Datetime2 => Model.MainInfo.Datetime2?.ToString("yyyy-MM-dd HH:mm"),
                                    (int)DataTypeEnum.Datetime3 => Model.MainInfo.Datetime3?.ToString("yyyy-MM-dd HH:mm"),

                                    (int)DataTypeEnum.CreatedBy => Model.MainInfo.CreatedBy,
                                    (int)DataTypeEnum.CreatedAt => Model.MainInfo.CreatedAt.ToString("yyyy-MM-dd HH:mm"),

                                    _ => ""
                                };
                            }

                            <span>@value</span>
                        </div>

                    </div>
                }

            </div>
        </div>
    </div>
</div>
@section Scripts {
    <script>
        $(document).ready(function () {

			var token = localStorage.getItem('authToken');
            let valueId = `${@Model.MainInfo.Id}`;
            let inventoryId = `${@Model.BasicInfo.Id}`;

            $.ajax({
                url: '@Url.Action("GetAccessForInventory", "Users")'+'?inventoryId='+inventoryId,
                headers: {'Authorization': 'Bearer ' + token},
                method: 'GET',
                success: function (response) {
                    console.log(response);
                    if(response) {

                        $('#valueSettings').append(`
                            <a href="/InventoryValue/Edit?id=${valueId}&inventoryId=${inventoryId}"
                               class="btn btn-outline-secondary btn-sm me-2">
                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-pencil-square" viewBox="0 0 16 16">
                                    <path d="M15.502 1.94a.5.5 0 0 1 0 .706L14.459 3.69l-2-2L13.502.646a.5.5 0 0 1 .707 0l1.293 1.293zm-1.75 2.456-2-2L4.939 9.21a.5.5 0 0 0-.121.196l-.805 2.414a.25.25 0 0 0 .316.316l2.414-.805a.5.5 0 0 0 .196-.12l6.813-6.814z" />
                                    <path fill-rule="evenodd" d="M1 13.5A1.5 1.5 0 0 0 2.5 15h11a1.5 1.5 0 0 0 1.5-1.5v-6a.5.5 0 0 0-1 0v6a.5.5 0 0 1-.5.5h-11a.5.5 0 0 1-.5-.5v-11a.5.5 0 0 1 .5-.5H9a.5.5 0 0 0 0-1H2.5A1.5 1.5 0 0 0 1 2.5z" />
                                </svg>
                            </a>
                            <a href="#" id="deleteBtn" data-id="${valueId}" data-inventoryId="${inventoryId}"
                               class="btn btn-outline-secondary btn-sm">
                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-trash3" viewBox="0 0 16 16">
                                    <path d="M6.5 1h3a.5.5 0 0 1 .5.5v1H6v-1a.5.5 0 0 1 .5-.5M11 2.5v-1A1.5 1.5 0 0 0 9.5 0h-3A1.5 1.5 0 0 0 5 1.5v1H1.5a.5.5 0 0 0 0 1h.538l.853 10.66A2 2 0 0 0 4.885 16h6.23a2 2 0 0 0 1.994-1.84l.853-10.66h.538a.5.5 0 0 0 0-1zm1.958 1-.846 10.58a1 1 0 0 1-.997.92h-6.23a1 1 0 0 1-.997-.92L3.042 3.5zm-7.487 1a.5.5 0 0 1 .528.47l.5 8.5a.5.5 0 0 1-.998.06L5 5.03a.5.5 0 0 1 .47-.53Zm5.058 0a.5.5 0 0 1 .47.53l-.5 8.5a.5.5 0 1 1-.998-.06l.5-8.5a.5.5 0 0 1 .528-.47M8 4.5a.5.5 0 0 1 .5.5v8.5a.5.5 0 0 1-1 0V5a.5.5 0 0 1 .5-.5" />
                                </svg>
                            </a>
                        `);
                    }
                },
                error: function (error) {
                    console.log('Failed to get inventory access info' + error);                    
                }
            });                      
		});

        $(document).on("click", "#deleteBtn", function (e) {

            e.preventDefault();
            var token = localStorage.getItem('authToken');

            var id = $(this).data("id");
            let inventoryId = $(this).data("inventoryId");

            var confirmation = confirm("Are you sure you want to delete this item?");

            if (confirmation === true) {

                $.ajax({
                    url: '@Url.Action("Delete", "InventoryValue")'+'?valueId='+id,
                    headers: {'Authorization': 'Bearer ' + token},
                    method: 'DELETE',
                    success: function (response) {
                        if(response.success) {
                            window.location.href = '@Url.Action("Index", "Inventory")'+'?inventoryId='+inventoryId;
                        }
                    },
                    error: function (error) {
                        console.log('Failed to delete value.' + error);
                        $('body').prepend('<div class="alert alert-danger" role="alert">Failed to delete inventory. Please try again. '+error.message+'</div>');
                    }
                });
            }
        });
    </script>
}
